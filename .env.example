# Core
APP_NAME=safe-arbitrage-bot
ENV=dev
LOG_LEVEL=INFO
LOG_JSON=true
TIMEZONE=UTC

# Database (PostgreSQL for prod, SQLite for local fallback)
DATABASE_URL=sqlite:///./arbitrage.db
SQL_ECHO=false

# Modes / safety
MODE=paper
LIVE_ENABLE_FLAG=false
LIVE_EXECUTION_ENABLED=false
LIVE_CONFIRMATION_TOKEN=CHANGE_ME_LIVE_TOKEN
CONTROL_API_TOKEN=CHANGE_ME_CONTROL_TOKEN
ALLOW_LIVE_WITHOUT_TOKEN=false
GLOBAL_KILL_SWITCH=false

# Chains
HYPEREVM_CHAIN_ID=999
HYPEREVM_RPC_URL=https://rpc.hyperliquid.xyz/evm
BASE_CHAIN_ID=8453
BASE_RPC_URL=https://mainnet.base.org

# Assets / allowlists (replace with real checksummed addresses)
HYPEREVM_USDC=0x0000000000000000000000000000000000000001
HYPEREVM_USDT0=0x0000000000000000000000000000000000000002
ALLOWLISTED_TOKENS=0x0000000000000000000000000000000000000001,0x0000000000000000000000000000000000000002
ALLOWLISTED_ROUTERS=0x0000000000000000000000000000000000000010
ALLOWLISTED_POOLS=ramses_v3_usdc_usdt0_5,hybra_v3_usdt0_usdc_5,ramses_v3_usdt0_usdc_5,hybra_v3_usdc_usdt0_5

# Live thresholds (conservative)
LIVE_MIN_NET_EDGE_BPS=30
LIVE_MIN_EDGE_PERSIST_SECONDS=8
LIVE_MAX_SLIPPAGE_BPS=2
LIVE_MIN_PROFIT_ABSOLUTE_USDC=0.50
LIVE_MAX_NOTIONAL_USDC=100
LIVE_MAX_NOTIONAL_PCT_OF_SMALLER_POOL=0.0002
LIVE_MAX_TRADES_PER_ROUTE_PER_10M=3
LIVE_MAX_CONSECUTIVE_FAILURES_PER_ROUTE=1
LIVE_MAX_CONSECUTIVE_LOSSES_PER_ROUTE=2
GLOBAL_DAILY_DD_STOP_PCT=0.005
GLOBAL_STALE_QUOTE_STOP_SECONDS=3

# Depeg / abnormal guard
DEPEG_THRESHOLD_BPS=50
RPC_ERROR_RATE_STOP_PCT_5M=0.05
GAS_SPIKE_MULTIPLIER=1.5
LIQUIDITY_DROP_STOP_PCT=0.30

# Shadow thresholds
SHADOW_MIN_NET_EDGE_BPS=125
SHADOW_MIN_EDGE_PERSIST_SECONDS=20
SHADOW_MAX_SLIPPAGE_BPS=10
SHADOW_NOTIONAL_USDC=100
SHADOW_STALE_QUOTE_SECONDS=5

# Fees fallback
BYBIT_MAKER_FEE_BPS_FALLBACK=10
BYBIT_TAKER_FEE_BPS_FALLBACK=15
MEXC_MAKER_FEE_BPS_FALLBACK=0
MEXC_TAKER_FEE_BPS_FALLBACK=5

# Cost model buffers
COST_QUOTE_DRIFT_BUFFER_BPS=3
COST_SLIPPAGE_BUFFER_BPS=2
COST_ROUTER_OVERHEAD_BPS=1
COST_FAILED_TX_ALLOWANCE_BPS=2
COST_SAFETY_MARGIN_BPS=2

# Alerting
DISCORD_WEBHOOK_URL=
ALERT_FAILURE_STOP_THRESHOLD=10

# Runtime jobs
QUOTE_POLL_INTERVAL_SECONDS=1.0
HEALTH_POLL_INTERVAL_SECONDS=5.0

# Local simulation / mock market data
USE_MOCK_MARKET_DATA=true
MOCK_HYPEREVM_USDC_USDT0_MID=1.0000
MOCK_BASE_VIRTUAL_USDC_MID=1.0000
GAS_PRICE_GWEI_DEFAULT=0.05
GAS_TOKEN_PRICE_USDC=2500